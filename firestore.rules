rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Hjälpfunktion: Kollar om inloggad användare är en lärare
    function isTeacher() {
      return request.auth != null 
             && request.auth.token.email != null
             && (request.auth.token.email.matches('.*@nyamunken\\.se') || request.auth.token.email.matches('.*@utb\\.linkoping\\.se'))
             && !request.auth.token.email.matches('.*[0-9]{3}.*');
    }

    // Hjälpfunktion: Kollar om användaren får skapa ett rum (Rate limit: 30 sekunder)
    function canCreateRoom() {
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return request.auth != null && (
        !exists(userDoc) || 
        get(userDoc).data.lastRoomCreated < request.time - duration.value(30, 's')
      );
    }

    // --- NYTT: Användarlogg för Rate Limiting ---
    match /users/{uid} {
      // Man får läsa och skriva sitt eget dokument för att uppdatera tidsstämpeln
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // --- Hemligheter (t.ex. API-nycklar) ---
    match /secrets/{docId} {
      allow read: if isTeacher();
      allow write: if false; 
    }

    // --- Rum och Buzzer-logik ---
    match /rooms/{roomId} {
      allow read: if true;
      
      // Enbart tillåtet att skapa om man väntat 30 sekunder sedan sist
      allow create: if canCreateRoom();
      
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.hostUid;
      
      match /players/{uid} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == uid;

        // Elev får bara ändra 'vote'-fältet
        allow update: if request.auth != null && request.auth.uid == uid
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['vote']);

        // Host får ändra allt
        allow write: if request.auth != null && get(/databases/$(database)/documents/rooms/$(roomId)).data.hostUid == request.auth.uid;
      }

      match /buzzes/{buzzId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == buzzId && get(/databases/$(database)/documents/rooms/$(roomId)).data.locked == false;
        allow delete: if request.auth != null && get(/databases/$(database)/documents/rooms/$(roomId)).data.hostUid == request.auth.uid;
      }
    }
    
    // --- Delade bräden (Skydd mot spam) ---
    // Obs: request.resource.size finns inte för Firestore-dokument (endast Cloud Storage),
    // så vi begränsar istället de enskilda strängfältens längd.
    match /sharedBoards/{boardId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.name is string
                    && request.resource.data.name.size() < 100
                    && request.resource.data.questionsJson is string
                    && request.resource.data.questionsJson.size() < 50000
                    && (!('answersJson' in request.resource.data.keys())
                        || request.resource.data.answersJson == null
                        || (request.resource.data.answersJson is string
                            && request.resource.data.answersJson.size() < 20000));
      allow update, delete: if false;
    }
  }
}
