rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Hjälpfunktion: Kollar om inloggad användare är en lärare
    function isTeacher() {
      return request.auth != null 
             && request.auth.token.email != null
             && request.auth.token.email.matches('.*@nyamunken\\.se')
             && !request.auth.token.email.matches('.*[0-9]{3}.*');
    }

    // --- NYTT: Hemligheter (t.ex. API-nycklar) ---
    match /secrets/{docId} {
      // Endast verifierade lärare får läsa dokumentet
      allow read: if isTeacher();
      // Ingen får skriva från klienten (du lägger in nyckeln manuellt i Firebase Console)
      allow write: if false; 
    }

    // --- Dina befintliga regler ---
    match /rooms/{roomId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.hostUid;
      
      match /players/{uid} {
        allow read: if true;
        // Elev får skapa sin profil
        allow create: if request.auth != null && request.auth.uid == uid;

        // ANTI-FUSK: Elev får uppdatera profilen, MEN de får BARA ändra fältet 'vote'.
        allow update: if request.auth != null && request.auth.uid == uid
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['vote']);

        // Host får ändra allt
        allow write: if request.auth != null && get(/databases/$(database)/documents/rooms/$(roomId)).data.hostUid == request.auth.uid;
      }
      match /buzzes/{buzzId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == buzzId && get(/databases/$(database)/documents/rooms/$(roomId)).data.locked == false;
        allow delete: if request.auth != null && get(/databases/$(database)/documents/rooms/$(roomId)).data.hostUid == request.auth.uid;
      }
    }
    
    match /sharedBoards/{boardId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
